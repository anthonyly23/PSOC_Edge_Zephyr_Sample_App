&ipc0 {
	status = "okay";

	mbox0: mbox0 {
		#mbox-cells = <1>;
		compatible = "infineon,mbox-pipe";
		ipc-pipe-ep0-addr = <1>;
		ipc-pipe-ep1-addr = <2>;

		ipc-configs =  <&ipc0 4 4 4>, /* IPC config for EP0 */
				       <&ipc0 5 5 4>; /* IPC config for EP1 */
		status = "okay";
	};
};
